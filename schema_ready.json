{
  "type": "object",
  "properties": {
    "log": {
      "x-containerAttributes": {
        "id": "section-log",
        "class": "config-section"
      },
      "type": "object",
      "title": "Log",
      "description": "Logging configuration",
      "properties": {
        "disabled": {
          "x-format": "checkbox",
          "type": "boolean",
          "title": "Disable logging",
          "description": "Disable logging output completely",
          "default": false
        },
        "level": {
          "type": "string",
          "title": "Log level",
          "description": "Logging level",
          "enum": [
            "trace",
            "debug",
            "info",
            "warn",
            "error",
            "fatal",
            "panic"
          ],
          "default": "info"
        },
        "output": {
          "type": "string",
          "title": "Output file",
          "description": "Path to log file (if empty, logs go to console)",
          "default": "box.log"
        },
        "timestamp": {
          "x-format": "checkbox",
          "type": "boolean",
          "title": "Include timestamp",
          "description": "Add timestamp to each log line",
          "default": true
        }
      },
      "additionalProperties": false
    },
    "dns": {
      "x-containerAttributes": {
        "id": "section-dns",
        "class": "config-section"
      },
      "type": "object",
      "title": "DNS",
      "properties": {
        "Servers": {
          "type": "array",
          "x-format": "nav-vertical",
          "x-arrayAddContent": "Add DNS server",
          "x-enableCollapseToggle": true,
          "x-collapseToggleContent": "",
          "x-arrayMove": true,
          "x-arrayMoveDownContent": "",
          "x-arrayMoveUpContent": "",
          "x-arrayDeleteContent": "Delete",
          "x-arrayDeleteAll": true,
          "x-arrayDeleteAllContent": "Delete all servers",
          "x-titleTemplate": "{{ i1 }}) {{ value.tag }}",
          "items": {
            "type": "object",
            "title": "{{ value.tag }}",
            "x-format": "grid",
            "properties": {
              "type": {
                "x-grid": {
                  "columns": 6
                },
                "type": "string",
                "title": "Protocol Type",
                "enum": [
                  "https",
                  "tls",
                  "udp",
                  "hosts",
                  "FakeIP"
                ],
                "default": "https"
              },
              "tag": {
                "x-grid": {
                  "columns": 6
                },
                "type": "string",
                "title": "Tag",
                "default": "dns-server"
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "https"
                    }
                  }
                },
                "then": {
                  "type": "object",
                  "x-format": "grid",
                  "properties": {
                    "server": {
                      "type": "string",
                      "title": "Server",
                      "x-grid": {
                        "columns": 6
                      }
                    },
                    "server_port": {
                      "type": "integer",
                      "title": "Port",
                      "default": 853,
                      "x-grid": {
                        "columns": 6
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "tls"
                    }
                  }
                },
                "then": {
                  "type": "object",
                  "x-format": "grid",
                  "properties": {
                    "server": {
                      "type": "string",
                      "title": "Server",
                      "x-grid": {
                        "columns": 6
                      }
                    },
                    "server_port": {
                      "type": "integer",
                      "title": "Port",
                      "default": 53,
                      "x-grid": {
                        "columns": 6
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "udp"
                    }
                  }
                },
                "then": {
                  "type": "object",
                  "x-format": "grid",
                  "properties": {
                    "server": {
                      "type": "string",
                      "title": "UDP Address",
                      "default": "8.8.8.8",
                      "x-grid": {
                        "columns": 6
                      }
                    },
                    "server_port": {
                      "type": "integer",
                      "title": "Port",
                      "default": 53,
                      "x-grid": {
                        "columns": 6
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "hosts"
                    }
                  }
                },
                "then": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "array",
                      "x-format": "table",
                      "x-arrayAddContent": "Add",
                      "x-arrayMove": false,
                      "x-arrayDeleteContent": "",
                      "x-arrayDeleteAll": true,
                      "x-arrayDeleteAllContent": "Delete all",
                      "title": "Hosts Paths",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "FakeIP"
                    }
                  }
                },
                "then": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string",
                      "title": "inet4_range",
                      "default": "198.18.0.0/15"
                    }
                  }
                }
              }
            ]
          }
        },
        "rules": {
          "x-format": "nav-vertical",
          "x-arrayAddContent": "Add rule",
          "x-arrayDeleteContent": "Delete rule",
          "x-enableCollapseToggle": true,
          "x-collapseToggleContent": "",
          "x-arrayDeleteAll": true,
          "x-arrayDeleteAllContent": "Delete all rules",
          "x-arrayMove": true,
          "x-arrayMoveDownContent": "",
          "x-arrayMoveUpContent": "",
          "x-titleTemplate": "Rule #{{ i1 }}",
          "type": "array",
          "title": "Rules",
          "items": {
            "type": "object",
            "title": "Rule #{{ i1 }}",
            "x-deactivateNonRequired": true,
            "x-enablePropertiesToggle": true,
            "properties": {
              "inbound": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "ip_version": {
                "type": "integer",
                "enum": [
                  4,
                  6
                ]
              },
              "network": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "tcp",
                    "udp"
                  ]
                }
              },
              "protocol": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "domain": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "domain_suffix": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "domain_keyword": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "domain_regex": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rule_set": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "invert": {
                "type": "boolean",
                "default": false
              }
            }
          }
        },
        "final": {
          "type": "string",
          "title": "Final Server",
          "description": "The tag of the server to use as a fallback"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "prefer_ipv4",
            "prefer_ipv6",
            "ipv4_only",
            "ipv6_only"
          ]
        },
        "independent_cache": {
          "x-format": "checkbox",
          "type": "boolean",
          "default": false
        },
        "reverse_maping": {
          "x-format": "checkbox",
          "type": "boolean",
          "default": false
        }
      }
    },
    "endpoints": {
      "x-containerAttributes": {
        "id": "section-endpoints",
        "class": "config-section"
      },
      "type": "array",
      "title": "Endpoints",
      "x-format": "nav-horizontal",
      "x-arrayAddContent": "Add endpoint",
      "x-arrayMove": false,
      "x-arrayDeleteContent": "",
      "x-arrayDeleteAll": true,
      "x-arrayDeleteAllContent": "Delete all endpoints",
      "x-titleTemplate": "{{ i1 }}) {{ value.tag }}",
      "items": {
        "type": "object",
        "title": "{{ value.tag }}",
        "x-format": "grid",
        "properties": {
          "type": {
            "type": "string",
            "title": "type",
            "enum": [
              "wireguard",
              "tailscale"
            ],
            "default": "wireguard",
            "x-grid": {
              "columns": 6
            }
          },
          "tag": {
            "type": "string",
            "title": "Tag",
            "default": "wg-in",
            "x-grid": {
              "columns": 6
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "wireguard"
                }
              }
            },
            "then": {
              "type": "object",
              "x-deactivateNonRequired": true,
              "x-enablePropertiesToggle": true,
              "x-propertiesToggleContent": "Toggle properties",
              "properties": {
                "system": {
                  "type": "boolean",
                  "x-format": "checkbox",
                  "title": "System Mode"
                },
                "mtu": {
                  "type": "integer",
                  "default": 1408,
                  "title": "MTU"
                },
                "server": {
                  "type": "array",
                  "title": "Server",
                  "x-format": "table",
                  "x-arrayDeleteContent": "",
                  "x-arrayAddContent": "Add adress",
                  "x-arrayMove": false,
                  "items": {
                    "type": "string",
                    "x-inputAttributes": {
                      "placeholder": "IP adress or domain name"
                    }
                  }
                },
                "private_key": {
                  "type": "string",
                  "title": "Private Key"
                },
                "peers": {
                  "type": "array",
                  "x-format": "nav-vertical",
                  "x-arrayAddContent": "Add peer",
                  "x-arrayMove": false,
                  "x-arrayDeleteContent": "",
                  "x-arrayDeleteAll": true,
                  "x-arrayDeleteAllContent": "Delete all peers",
                  "x-enableCollapseToggle": true,
                  "x-collapseToggleContent": "",
                  "minItems": 1,
                  "title": "Peers List",
                  "x-titleTemplate": "{{ i1 }}) {{ value.peerTag }}",
                  "items": {
                    "type": "object",
                    "x-enableCollapseToggle": true,
                    "x-collapseToggleContent": "",
                    "x-enablePropertiesToggle": true,
                    "x-propertiesToggleContent": "Toggle properties",
                    "x-format": "grid",
                    "title": "{{value.peerTag}}",
                    "properties": {
                      "peerTag": {
                        "title": "Tag",
                        "type": "string",
                        "description": "Purely cosmetic value to use through UI, will NOT be used in final config"
                      },
                      "address": {
                        "type": "string",
                        "x-grid": {
                          "columns": 6
                        }
                      },
                      "port": {
                        "type": "integer",
                        "x-grid": {
                          "columns": 6
                        }
                      },
                      "public_key": {
                        "type": "string"
                      },
                      "allowed_ips": {
                        "type": "array",
                        "x-format": "table",
                        "x-arrayDeleteContent": "",
                        "x-arrayAddContent": "Add adress",
                        "x-arrayMove": false,
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "public_key",
                      "allowed_ips"
                    ]
                  }
                }
              },
              "required": [
                "type",
                "tag",
                "server",
                "private_key",
                "peers"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "tailscale"
                }
              }
            }
          }
        ]
      }
    },
    "inbounds": {
      "x-containerAttributes": {
        "id": "section-inbounds",
        "class": "config-section"
      },
      "type": "array",
      "title": "Inbounds",
      "x-format": "nav-horizontal",
      "x-arrayAddContent": "Add inbound",
      "x-arrayMove": false,
      "x-arrayDeleteContent": "",
      "x-arrayDeleteAll": true,
      "x-arrayDeleteAllContent": "Delete all inbounds",
      "x-titleTemplate": "{{ value.tag}} ({{ value.type }})",
      "items": {
        "type": "object",
        "title": "{{ value.tag}} ({{ value.type }})",
        "properties": {
          "type": {
            "type": "string",
            "title": "Inbound type",
            "enum": [
              "tproxy",
              "mixed",
              "direct",
              "VLESS"
            ]
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "direct"
                }
              }
            },
            "then": {
              "type": "object",
              "properties": {
                "tag": {
                  "type": "string",
                  "default": "direct"
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "VLESS"
                }
              }
            },
            "then": {
              "type": "object",
              "x-deactivateNonRequired": true,
              "x-enablePropertiesToggle": true,
              "x-propertiesToggleContent": "Toggle properties",
              "properties": {
                "tag": {
                  "type": "string",
                  "default": "VLESS_in"
                },
                "server": {
                  "type": "string"
                },
                "server_port": {
                  "type": "integer"
                },
                "uuid": {
                  "type": "string",
                  "x-inputAttributes": {
                    "placeholder": "bf000d23-0752-40b4-affe-68f7707a9661"
                  }
                },
                "flow": {
                  "type": "string",
                  "default": "xtls-rprx-vision"
                },
                "network": {
                  "type": "string",
                  "default": "tcp"
                },
                "tls": {},
                "packet_encoding": {
                  "type": "string",
                  "default": "tcp"
                },
                "multiplex": {},
                "transport": {}
              },
              "required": [
                "tag",
                "type",
                "server",
                "server_port",
                "uuid"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "tproxy"
                }
              }
            },
            "then": {
              "type": "object",
              "x-deactivateNonRequired": true,
              "x-enablePropertiesToggle": true,
              "x-propertiesToggleContent": "Toggle properties",
              "properties": {
                "tag": {
                  "type": "string",
                  "default": "trpoxy-out"
                },
                "listen": {
                  "type": "string"
                },
                "listen_port": {
                  "type": "integer"
                },
                "tcp_fast_open": {
                  "type": "boolean",
                  "x-format": "checkbox",
                  "default": false
                },
                "udp_fragment": {
                  "type": "boolean",
                  "x-format": "checkbox",
                  "default": false
                }
              },
              "required": [
                "tag",
                "type"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "mixed"
                }
              }
            },
            "then": {
              "type": "object",
              "x-deactivateNonRequired": true,
              "x-enablePropertiesToggle": true,
              "x-propertiesToggleContent": "Toggle properties",
              "properties": {
                "tag": {
                  "type": "string",
                  "default": "mixed-in"
                },
                "users": {
                  "type": "array",
                  "title": "Users",
                  "x-format": "nav-vertical",
                  "x-arrayAddContent": "Add user",
                  "x-enableCollapseToggle": true,
                  "x-collapseToggleContent": "",
                  "x-arrayMove": false,
                  "x-arrayDeleteContent": "",
                  "x-arrayDeleteAll": true,
                  "x-arrayDeleteAllContent": "Delete all",
                  "x-titleTemplate": "{{ i1 }}) {{ value.username }}",
                  "items": {
                    "type": "object",
                    "title": "{{ value.username }}",
                    "properties": {
                      "username": {
                        "type": "string",
                        "title": "username",
                        "default": "Alice"
                      },
                      "password": {
                        "type": "string",
                        "title": "password"
                      }
                    }
                  }
                },
                "set_system_proxy": {
                  "type": "boolean",
                  "x-format": "checkbox",
                  "title": "set_system_proxy",
                  "default": false
                }
              },
              "required": [
                "type",
                "tag"
              ]
            }
          }
        ]
      }
    },
    "outbounds": {
      "x-containerAttributes": {
        "id": "section-outbounds",
        "class": "config-section"
      },
      "type": "array",
      "title": "Outbounds",
      "x-format": "nav-vertical",
      "x-arrayAddContent": "Add outound",
      "x-arrayMove": false,
      "x-arrayDeleteContent": "",
      "x-arrayDeleteAll": true,
      "x-arrayDeleteAllContent": "Delete all outbounds",
      "x-titleTemplate": "{{ value.tag}} ({{ value.type }})",
      "items": {
