    },
    "route": {
      "x-containerAttributes": {
        "id": "section-route",
        "class": "config-section"
      },
      "type": "object",
      "title": "Route"
    },
    "experimental": {
      "x-containerAttributes": {
        "id": "section-experimental",
        "class": "config-section"
      },
      "type": "object",
